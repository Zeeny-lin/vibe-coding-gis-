# DeepSeek AI API配置
# 获取API密钥: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-api-key-here

# 可选：自定义API地址（默认为DeepSeek官方）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 可选：指定模型
# DEEPSEEK_MODEL=deepseek-chat

# Antigravity AI 代理配置
# 本地代理服务，默认端口8045
ANTIGRAVITY_API_KEY=your-antigravity-api-key
ANTIGRAVITY_BASE_URL=http://127.0.0.1:8045/v1

# AI提供商选择 (deepseek 或 antigravity)
AI_PROVIDER=antigravity
